# Database (Supabase — connection pooling for app, direct for migrations)
# ضع هذه المتغيرات في Vercel Dashboard → Project Settings → Environment Variables
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Auth
# في Vercel: NEXTAUTH_URL = https://<your-project>.vercel.app (غيّرها بعد أول deploy)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-hex-string"
